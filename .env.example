# Server-only: used by backend services for Postgres access.
# Local (Docker Compose): postgresql://diana:diana@localhost:5432/diana
# Neon: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://diana:diana@localhost:5432/diana
ENVIRONMENT=development
# Optional (recommended in production): comma-separated frontend origins allowed by CORS.
# Example: https://YOUR-VERCEL-FRONTEND.vercel.app,https://www.YOUR-DOMAIN.com
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Frontend-safe: must point to your deployed HTTPS backend (Render, etc.).
# Example: https://your-service.onrender.com
EXPO_PUBLIC_BACKEND_URL=https://your-service.onrender.com
OPENAI_API_KEY=
EMERGENT_LLM_KEY=
