# Backend-only: used by FastAPI runtime (never expose to frontend).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"
ENVIRONMENT="development"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8081,http://localhost:19006"

# Frontend-safe: API base URL only (never a database URL).
EXPO_PUBLIC_BACKEND_URL="http://localhost:8000"

# Optional backend secrets/keys (server-side only)
OPENAI_API_KEY=""
EMERGENT_LLM_KEY=""

# Production guidance:
# Backend host env vars:
#   DATABASE_URL=<real Neon/Postgres URL>
#   ENVIRONMENT=production
#   CORS_ALLOWED_ORIGINS=https://YOUR-VERCEL-FRONTEND.vercel.app
# Frontend Vercel env var:
#   EXPO_PUBLIC_BACKEND_URL=https://YOUR-RENDER-SERVICE.onrender.com
